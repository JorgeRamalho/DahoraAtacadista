# PostgreSQL do Windows / Docker Compose (porta 5432) — padrão após npm run db:up
DATABASE_URL="postgresql://dahora:dahora_dev@127.0.0.1:5432/dahora?schema=public"

# PostgreSQL embutido (sem Docker/serviço Windows): npm run db:embed
# DATABASE_URL="postgresql://dahora:dahora_dev@127.0.0.1:5433/dahora?schema=public"

# Cloud (Neon/Supabase):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

SESSION_SECRET="change-me-in-production-use-a-long-random-string"

# Ambiente
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Acesso por outros dispositivos na mesma Wi‑Fi:
# NEXT_PUBLIC_APP_URL="http://SEU_IP_LOCAL:3000"
# Suba com: npm run dev:lan

# Links das lojas (seção Baixe o app)
# NEXT_PUBLIC_PLAY_STORE_URL="https://play.google.com/store/apps/details?id=br.com.dahora.app"
# NEXT_PUBLIC_APP_STORE_URL="https://apps.apple.com/app/dahora-atacadista/id000000000"
