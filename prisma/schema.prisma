generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id                  String   @id @default(cuid())
  nomeCompleto        String
  nomeSocial          String?
  cpf                 String   @unique
  rg                  String?
  email               String   @unique
  telefone            String
  telefoneAlternativo String?
  dataNascimento      String
  genero              String?
  estadoCivil         String?
  cep                 String
  endereco            String
  numero              String
  complemento         String?
  bairro              String
  cidade              String
  estado              String   @db.Char(2)
  comoConheceu        String?
  senhaHash           String
  numeroCartao        String   @unique
  pontos              Int      @default(0)
  status              String   @default("ativo")
  aceiteMarketing     Boolean  @default(false)
  aceiteLgpdAt        DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tickets             Ticket[]
  duvidas             Duvida[]

  @@index([status])
  @@index([createdAt])
  @@index([cidade, estado])
}

model Ticket {
  id         String   @id @default(cuid())
  protocolo  String   @unique
  nome       String
  email      String
  telefone   String?
  assunto    String
  mensagem   String   @db.Text
  status     String   @default("aberto")
  prioridade String   @default("normal")
  clienteId  String?
  cliente    Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([clienteId])
}

model Duvida {
  id        String   @id @default(cuid())
  nome      String
  email     String
  pergunta  String   @db.Text
  resposta  String?  @db.Text
  status    String   @default("pendente")
  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([clienteId])
}

model Faq {
  id        String   @id @default(cuid())
  pergunta  String
  resposta  String   @db.Text
  categoria String
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([categoria, ativo, ordem])
}
